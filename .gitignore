yarn-error.log*

# ================================
# Alembic
# ================================
# keep alembic/versions tracked (migrations are source code)
alembic/__pycache__/
alembic/versions/__pycache__/
# don't ignore alembic.ini or alembic/env.py

# ================================
# spaCy model downloads / cache
# ================================
.spacy/
spacy_models/
en_core_web_sm/
en_core_web_md/
en_core_web_lg/

